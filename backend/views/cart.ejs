<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Your Cart</title>
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const container = document.getElementById('cart-items');
            let total = 0;

            if (cart.length === 0) {
                container.innerHTML = '<p class="text-center text-xl mt-10">Your cart is empty.</p>';
                return;
            }

            cart.forEach(item => {
                total += item.price;
                const div = document.createElement('div');
                div.className = 'flex items-center justify-between p-4 border-b';
                div.innerHTML = `
                    <div class="flex items-center space-x-4">
                        <img src="${item.imgSrc}" class="w-20 h-20 rounded" alt="${item.name}">
                        <span class="text-lg font-semibold">${item.name}</span>
                    </div>
                    <span class="text-lg font-bold">₹${item.price}</span>
                `;
                container.appendChild(div);
            });

            document.getElementById('total').textContent = 'Total: ₹' + total;
        });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6">
    <h1 class="text-3xl font-bold mb-6 text-center">Your Cart</h1>
    <div id="cart-items" class="bg-white max-w-4xl mx-auto shadow-lg rounded p-6"></div>
    <div class="text-center mt-8">
        <p id="total" class="text-2xl font-bold mb-4"></p>
        <button class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">Checkout</button>
    </div>
</body>
</html>
